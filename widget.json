{
  "id": "com.yourcompany.sac.advancedaiplanningwidget",
  "version": "1.8.9",
  "name": "Arnav",
  "description": "Advanced SAC custom widget for AI-assisted planning actions, insights, and model suggestions.",
  "newInstancePrefix": "AI Planning Widget",
  "vendor": "Arnav",
  "license": "Apache-2.0",
  "webcomponents": [
    {
      "kind": "main",
      "tag": "com-yourcompany-sac-advanced-ai-planning-widget",
      "url": "https://arnav973.github.io/AIAGENT/webcomponent.js",
      "integrity": "",
      "ignoreIntegrity": true
    },
    {
      "kind": "styling",
      "tag": "com-yourcompany-sac-advanced-ai-planning-widget-styling",
      "url": "https://arnav973.github.io/AIAGENT/styling.js",
      "integrity": "",
      "ignoreIntegrity": true
    }
  ],
  "properties": {
    "title": {
      "type": "string",
      "default": "AI Planning Assistant"
    },
    "subtitle": {
      "type": "string",
      "default": "Ask for planning insights, measures, dimensions, and improvements"
    },
    "themeMode": {
      "type": "string",
      "default": "dark"
    },
    "apiBaseUrl": {
      "type": "string",
      "default": "https://your-api.example.com"
    },
    "apiPath": {
      "type": "string",
      "default": "/agent/planning"
    },
    "authToken": {
      "type": "string",
      "default": ""
    },
    "placeholder": {
      "type": "string",
      "default": "Example: Add a measure GrossMargin = Revenue - COGS"
    },
    "defaultPrompt": {
      "type": "string",
      "default": ""
    },
    "primaryColor": {
      "type": "string",
      "default": "#5b8def"
    },
    "accentColor": {
      "type": "string",
      "default": "#22c55e"
    },
    "borderRadius": {
      "type": "integer",
      "default": 16
    },
    "showHeader": {
      "type": "boolean",
      "default": true
    },
    "showStatusBar": {
      "type": "boolean",
      "default": true
    },
    "allowSimulation": {
      "type": "boolean",
      "default": true
    },
    "compactMode": {
      "type": "boolean",
      "default": false
    }
  },
  "methods": {
    "runPrompt": {
      "description": "Run a prompt programmatically"
    },
    "setPrompt": {
      "description": "Set the prompt value"
    },
    "clearOutput": {
      "description": "Clear the output panel"
    },
    "setApiConfig": {
      "description": "Update API configuration at runtime"
    }
  },
  "events": {
    "onResult": {
      "description": "Fired when a result is returned"
    },
    "onError": {
      "description": "Fired when an error occurs"
    },
    "onAction": {
      "description": "Fired when a user clicks an action button"
    }
  }
}
