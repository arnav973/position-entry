{
  "id": "com.example.positionentry",
  "version": "16.0.0",
  "name": "Position Entry Widget",
  "description": "Position entry table widget for SAC",
  "newInstancePrefix": "PositionEntry",
  "vendor": "Arnav",
  "icon": "sap-icon://table-view",
  "webcomponents": [
    {
      "kind": "main",
      "tag": "com-example-position-entry",
      "url": "https://arnav973.github.io/position-entry/position-entry-widget.js",
      "integrity": "",
      "ignoreIntegrity": true
    }
  ],
  "properties": {
