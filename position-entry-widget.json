      "description": "Set manage cell value programmatically",
      "parameters": [
        {
          "name": "rowIndex",
          "type": "integer"
        },
        {
          "name": "fieldName",
          "type": "string"
        },
        {
          "name": "value",
          "type": "string"
        }
      ]
