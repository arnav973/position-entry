        {
          "name": "optionsStr",
          "type": "string"
        }
      ]
    },
    "setManageRowOptions": {
      "description": "Set manage row-specific dropdown options",
      "parameters": [
        {
          "name": "rowIndex",
          "type": "integer"
        },
        {
          "name": "fieldName",
          "type": "string"
        },
        {
          "name": "optionsStr",
          "type": "string"
        }
      ]
    },
    "setCellValue": {
      "description": "Set create cell value programmatically",
